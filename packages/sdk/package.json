{
  "name": "@soterai/core",
  "version": "0.2.0",
  "description": "Soter is a safety layer for AI chatbots, agents, RAG systems, and LLM applications.",
  "license": "Apache-2.0",
  "type": "commonjs",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "default": "./dist/next.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "default": "./dist/express.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test test/*.test.js",
    "prepublishOnly": "npm test"
  },
  "engines": { "node": ">=18.18" },
  "keywords": [
    "soter",
    "ai-chatbot",
    "llm-security",
    "prompt-injection",
    "jailbreak-detection",
    "pii-redaction",
    "chatbot-protection",
    "rag-security",
    "ai-safety",
    "ai-agents"
  ],
  "devDependencies": {
    "typescript": "5.7.2"
  },
  "publishConfig": { "access": "public" }
}
