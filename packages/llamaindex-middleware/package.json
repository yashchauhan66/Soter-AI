{
  "name": "@soterai/llamaindex-middleware",
  "private": true,
  "version": "0.2.0",
  "description": "Soter is a safety layer for AI chatbots, agents, RAG systems, and LLM applications.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": { "node": ">=18.18" },
  "keywords": [
    "soter",
    "ai-chatbot",
    "llm-security",
    "prompt-injection",
    "jailbreak-detection",
    "pii-redaction",
    "chatbot-protection",
    "rag-security",
    "ai-safety",
    "ai-agents"
  ],
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "publishConfig": { "access": "public" }
}
