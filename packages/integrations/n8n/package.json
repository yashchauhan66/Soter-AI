{
  "name": "n8n-nodes-soterai",
  "version": "0.2.0",
  "description": "SoterAI adds prompt injection, jailbreak, PII leakage, and unsafe output protection to AI workflows.",
  "license": "MIT",
  "author": {
    "name": "SoterAI",
    "email": "support@soterai.dev",
    "url": "https://soterai.publicvm.com"
  },
  "homepage": "https://github.com/yashchauhan66/Soter-AI/tree/main/packages/integrations/n8n",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yashchauhan66/Soter-AI.git",
    "directory": "packages/integrations/n8n"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ai-security",
    "prompt-injection",
    "jailbreak",
    "pii",
