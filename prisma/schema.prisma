// ── Shadow AI Scanner ─────────────────────────────────────────────────────────

model ShadowAiScan {
  id             String        @id @default(cuid())
  organizationId String
  projectId      String?
  scanType       String        @default("FULL")
  status         String        @default("PENDING")
  providerCount  Int           @default(0)
  modelCount     Int           @default(0)
  riskFindings   Int           @default(0)
  findings       ShadowAiFinding[]
  startedAt      DateTime?
  completedAt    DateTime?
  error          String?
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([status])
}

model ShadowAiFinding {
  id             String       @id @default(cuid())
  scanId         String
  scan           ShadowAiScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  findingType    String
  providerName   String?
  modelName      String?
  riskLevel      String       @default("MEDIUM")
  evidence       String?      @db.Text
  recommendation String?
  createdAt      DateTime     @default(now())

  @@index([scanId])
  @@index([findingType, riskLevel])
}

// ── MCP Credential Vault ──────────────────────────────────────────────────────

model McpCredentialVault {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String?
  name            String
  serverUrl       String
  description     String?
  encryptedSecret String   @db.Text
  secretPreview   String
  keyVersion      String?
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  status          String   @default("ACTIVE")
  createdById     String?
  accessLogs      McpCredentialAccessLog[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, status])
  @@index([projectId])
}

model McpCredentialAccessLog {
  id             String            @id @default(cuid())
  vaultId        String
  vault          McpCredentialVault @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  action         String
  actorUserId    String?
  success        Boolean
  ipAddress      String?
  createdAt      DateTime          @default(now())

  @@index([vaultId, createdAt])
}

