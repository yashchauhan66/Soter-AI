// ── AI Incident Forensics ─────────────────────────────────────────────────────

model ForensicReport {
  id              String   @id @default(cuid())
  incidentId      String
  incident        Incident   @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  reportType      String     @default("INCIDENT_REPORT")
  status          String     @default("DRAFT")
  title           String
  summary         String     @db.Text
  timelineJson    Json?
  evidenceJson    Json?
  findingsJson    Json?
  recommendations String?    @db.Text
  createdById     String?
  evidence        ForensicEvidence[]
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([incidentId, reportType])
  @@index([incidentId, status])
}

model ForensicEvidence {
  id              String         @id @default(cuid())
  reportId        String
  report          ForensicReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
