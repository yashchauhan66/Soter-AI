  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "SoterAI API key obtained from the dashboard. Must be kept server-side."
      }
    },
    "schemas": {
      "GuardResult": {
        "type": "object",
        "properties": {
          "decision": { "type": "string", "enum": ["ALLOW", "BLOCK", "ESCALATE"] },
          "action": { "type": "string", "enum": ["ALLOW", "BLOCK", "ESCALATE"] },
          "riskScore": { "type": "number", "minimum": 0, "maximum": 100 },
          "riskLevel": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
          "riskTypes": { "type": "array", "items": { "type": "string" } },
          "findings": { "type": "array", "items": { "$ref": "#/components/schemas/Finding" } },
          "redactedText": { "type": "string", "nullable": true }
        }
      },
      "Finding": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
          "message": { "type": "string" },
          "start": { "type": "integer" },
          "end": { "type": "integer" }
        }
      }
    }
  },
