DATABASE_URL="postgresql://postgres:replace-with-local-password@127.0.0.1:5432/cyberrakshak_guard?schema=public"
DEMO_USER_EMAIL="demo@cyberrakshak.dev"
DEMO_USER_PASSWORD="demo-cyberrakshak-2026"
API_KEY_PEPPER="replace-with-a-long-random-secret"
MAX_GUARD_TEXT_LENGTH="8000" 
DEFAULT_RPM="60"
PUBLIC_ANALYZE_RPM="20"

# Phase 2 plan limits (requests / month)
FREE_PLAN_LIMIT_PER_MONTH="100"
STARTER_LIMIT_PER_MONTH="10000"
PRO_LIMIT_PER_MONTH="50000"
AGENCY_LIMIT_PER_MONTH="250000"
ENTERPRISE_LIMIT_PER_MONTH="5000000"



# Phase 2 SDK / badge defaults
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CYBERRAKSHAK_API_KEY="ck_test_replace-with-server-side-api-key"

# ============================================================
# Phase 3: real auth, distributed state, billing, audit exports
# ============================================================

# NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-at-least-32-random-characters"
NEXTAUTH_SECRET="replace-with-at-least-32-random-characters"
NEXTAUTH_URL="http://localhost:3000"

# Audit export signing secret. Used to HMAC each row + manifest header.
# Falls back to API_KEY_PEPPER if not set; set explicitly in production.
AUDIT_EXPORT_SECRET=""

# Webhook worker. Cron drivers (Vercel Cron, Render Cron, GitHub Actions)
# call POST /api/admin/webhooks/process with this token in Authorization.
WEBHOOK_WORKER_TOKEN="replace-with-a-long-random-token"

# Upstash Redis (HTTP). When unset, the app falls back to in-memory rate
# limit + monthly metering with a console warning. Required for multi-
# instance deployments.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Razorpay billing. When unset, /api/billing/checkout returns sandbox
# (mock) orders so the UI flow stays exercisable in development.
# Activation requires verified webhook events in production.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Optional: map Razorpay plan ids to internal plans.
RAZORPAY_PLAN_STARTER=""
RAZORPAY_PLAN_PRO=""
RAZORPAY_PLAN_AGENCY=""

# Where billing CTAs send enterprise inquiries.
ENTERPRISE_CONTACT_EMAIL="sales@cyberrakshak.dev"

# ============================================================
# Phase 4: email, semantic detectors, encrypted secrets, workers
# ============================================================

# Email: mock (default), resend, aws-ses, or smtp
EMAIL_PROVIDER="mock"
EMAIL_FROM="CyberRakshak Guard <security@example.com>"
RESEND_API_KEY=""
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_TLS="false"
SMTP_HELO="cyberrakshak.local"

# Classifiers are additive. Rule-based guards always remain active.
ENABLE_SEMANTIC_DETECTORS="false"
ENABLE_MULTILINGUAL_DETECTORS="false"
ENABLE_HINDI_HINGLISH_DETECTION="false"

# Encrypted webhook signing-secret storage
SECRET_STORE_PROVIDER="local"
LOCAL_SECRET_STORE_KEY="replace-with-at-least-32-random-characters"
AWS_KMS_KEY_ID=""
GCP_KMS_KEY_ID=""
VAULT_ADDR=""
VAULT_TOKEN=""
VAULT_TRANSIT_KEY="cyberrakshak-webhooks"
# Set only when the Vault Transit key is configured as derived.
VAULT_TRANSIT_CONTEXT=""

# Phase 5 KMS provider settings
GCP_PROJECT_ID=""
GCP_LOCATION="global"
GCP_KEY_RING=""
GCP_CRYPTO_KEY=""
# Short-lived OAuth token for the REST adapter. Prefer workload identity in production.
GCP_KMS_ACCESS_TOKEN=""
AWS_KMS_KEY_ID=""
AWS_SESSION_TOKEN=""

# OCR and document sandbox
RAG_MAX_FILE_BYTES="10485760"
RAG_MAX_PAGES="50"
OCR_TIMEOUT_MS="30000"
OCR_LANGUAGES="eng+hin"

# Vector providers: memory (development), qdrant, or pgvector
VECTOR_PROVIDER="memory"
QDRANT_URL=""
QDRANT_API_KEY=""
PGVECTOR_DATABASE_URL=""
VECTOR_DIMENSIONS="64"
EMBEDDING_API_URL=""
EMBEDDING_API_KEY=""
# Never enable in production unless deterministic, non-semantic test vectors are explicitly intended.
VECTOR_ALLOW_LOCAL_EMBEDDINGS="false"

# Classifier evaluation
DETECTOR_VERSION="phase5-rule-v1"
PERSIST_CLASSIFIER_EVAL="false"

# Observability and SIEM
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_EXPORTER_OTLP_HEADERS=""
SIEM_WORKER_INTERVAL_MS="5000"
SIEM_WORKER_HEALTH_PORT="3097"

# Enterprise identity
SCIM_TOKEN_PEPPER="replace-with-at-least-32-random-characters"
SAML_SP_ENTITY_ID=""
SAML_SP_ACS_URL=""
SAML_SP_PRIVATE_KEY=""
SAML_SP_CERTIFICATE=""

# Phase 6 enterprise operations
POSTGRES_PASSWORD="replace-with-a-long-random-password"
REDIS_URL="redis://127.0.0.1:6379"
APP_ENV_FILE=".env.production"
BACKUP_DIR="./backups"
BASE_URL="http://127.0.0.1:3000"

# Always-on webhook worker and scheduled reports
WEBHOOK_WORKER_INTERVAL_MS="5000"
WEBHOOK_WORKER_HEALTH_PORT="3099"
BACKGROUND_WORKER_INTERVAL_MS="5000"
BACKGROUND_WORKER_HEALTH_PORT="3098"
REPORT_WORKER_TOKEN="replace-with-a-long-random-token"
REPORT_SIGNING_SECRET="replace-with-a-long-random-signing-secret"

# ============================================================
# Phase 11: competitive gap modules
# ============================================================

# Additive multilingual detector expansion. Rule-based detectors always remain active.
ENABLE_PHASE11_MULTILINGUAL_DETECTORS="false"

# Optional ML training/evaluation backend. Keep unset to use local heuristics.
ML_BACKEND=""
ML_API_URL=""
ML_API_KEY=""
ML_API_TIMEOUT_MS="5000"
PERSIST_RETRIEVAL_AUDIT="false"
GOOGLE_OAUTH_ACCESS_TOKEN=""

# Threat intelligence worker performs local validation only. Remote rule packs
# must be manually uploaded, approved, shadow-tested, and promoted.
THREAT_INTEL_WORKER_INTERVAL_MS="300000"
THREAT_INTEL_WORKER_HEALTH_PORT="3097"

# Agent firewall defaults are fail-closed for unknown tools.
AGENT_FIREWALL_DEFAULT_ACTION="DENY"
AGENT_FIREWALL_APPROVAL_THRESHOLD="70"
AGENT_FIREWALL_BLOCK_THRESHOLD="90"
