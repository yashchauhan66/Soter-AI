# ============================================================
# Phase 4: email, semantic detectors, encrypted secrets, workers
# ============================================================

# Email: mock (default), resend, aws-ses, or smtp
EMAIL_PROVIDER="mock"
EMAIL_FROM="CyberRakshak Guard <security@example.com>"
RESEND_API_KEY=""
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_TLS="false"
SMTP_HELO="cyberrakshak.local"

# Email verification enforcement for credentials login.
# Unset (default): enforced whenever a real email provider is configured or in
#   production; relaxed only for the mock provider in development.
# "true": always require a verified email before credentials login (use in
#   staging even while inspecting mock email).
# "false": never require it (local convenience only; do NOT use in production).
AUTH_REQUIRE_EMAIL_VERIFICATION=""

# Classifiers are additive. Rule-based guards always remain active.
ENABLE_SEMANTIC_DETECTORS="false"
ENABLE_MULTILINGUAL_DETECTORS="false"
ENABLE_HINDI_HINGLISH_DETECTION="false"

# Encrypted webhook signing-secret storage
